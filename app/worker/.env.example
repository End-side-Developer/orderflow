ORDERFLOW_ENV=local
ORDERFLOW_LOG_LEVEL=info
ORDERFLOW_WORKER_TASK_QUEUE=orderflow-default
ORDERFLOW_WORKER_TEMPORAL_HOST=localhost:7233
ORDERFLOW_WORKER_TEMPORAL_NAMESPACE=default
ORDERFLOW_WORKER_DATABASE_URL=postgresql+psycopg://orderflow:orderflow@localhost:5432/orderflow
ORDERFLOW_WORKER_REDIS_URL=redis://localhost:6379/1
ORDERFLOW_OTEL_ENDPOINT=http://localhost:4317

# AI provider keys (at least one required for AI-powered extraction)
ORDERFLOW_AI_DEFAULT_PROVIDER=gemini
ORDERFLOW_AI_DEFAULT_MODEL=gemini-2.0-flash
ORDERFLOW_AI_GEMINI_API_KEY=
ORDERFLOW_AI_GROQ_API_KEY=
ORDERFLOW_AI_TIMEOUT_SECONDS=45
